#!/bin/bash
# NEXUS OS — Protected Path Pre-commit Hook (Phase 3)
# Rejects commits that modify protected files/directories.
# Install: git config core.hooksPath /opt/nexus/.git-hooks
#
# NOTE: dev_assistant.py is intentionally NOT in this protected list.
# It is protected at the Python layer (dev_assistant.py itself checks
# protected paths before applying patches). The hook deliberately omits it
# so that Phase 5 self-update capability can allow the bot to modify its
# own source code via git commits without being blocked here.

PROTECTED_PATTERNS=(
    ".env"
    "keystore/"
    "password.txt"
    "contracts/deployed/"
    "swarm.key"
    "masterseed"
    "clef.ipc"
    "*.key"
    "*.pem"
    "id_rsa"
    "id_ed25519"
)

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

BLOCKED=""
for file in $STAGED; do
    for pattern in "${PROTECTED_PATTERNS[@]}"; do
        case "$pattern" in
            */) # Directory pattern
                if [[ "$file" == ${pattern}* ]]; then
                    BLOCKED="$BLOCKED\n  $file (matches $pattern)"
                fi
                ;;
            \**) # Wildcard pattern
                ext="${pattern#\*}"
                if [[ "$file" == *"$ext" ]]; then
                    BLOCKED="$BLOCKED\n  $file (matches $pattern)"
                fi
                ;;
            *) # Exact match (also matches as substring in path)
                if [[ "$file" == *"$pattern"* ]]; then
                    BLOCKED="$BLOCKED\n  $file (matches $pattern)"
                fi
                ;;
        esac
    done
done

if [ -n "$BLOCKED" ]; then
    echo "🛑 NEXUS OS Pre-commit Hook: Protected path violation!"
    echo -e "Blocked files:$BLOCKED"
    echo ""
    echo "To bypass (emergency only): git commit --no-verify"
    exit 1
fi

exit 0
