#!/bin/bash
# NEXUS OS Command Line Interface
# Usage: nexus-cli <command>

GATEWAY="http://localhost:8766"
CONFIG_DIR="/opt/nexus/config"
LOG_DIR="/opt/nexus/logs"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

cmd_help() {
    echo -e "${CYAN}${BOLD}NEXUS OS CLI${NC} — Your Data. Your Hardware. Your Rules."
    echo ""
    echo -e "  ${BOLD}nexus-cli status${NC}      Show system status (nodes, blockchain, services)"
    echo -e "  ${BOLD}nexus-cli wallet${NC}      Show wallet address and token balances"
    echo -e "  ${BOLD}nexus-cli dashboard${NC}   Open Command Center in browser"
    echo -e "  ${BOLD}nexus-cli health${NC}      Check all service health"
    echo -e "  ${BOLD}nexus-cli logs${NC}        Show recent system logs"
    echo -e "  ${BOLD}nexus-cli nodes${NC}       List connected nodes"
    echo -e "  ${BOLD}nexus-cli tasks${NC}       Show task queue"
    echo -e "  ${BOLD}nexus-cli help${NC}        Show this help message"
    echo ""
}

cmd_status() {
    echo -e "${CYAN}${BOLD}═══ NEXUS OS Status ═══${NC}"
    echo ""

    # Node role
    if [ -f "$CONFIG_DIR/node_config.json" ]; then
        role=$(python3 -c "import json; print(json.load(open('$CONFIG_DIR/node_config.json')).get('node_role','unknown'))" 2>/dev/null)
        echo -e "  Node Role:    ${BOLD}${role}${NC}"
    else
        echo -e "  Node Role:    ${YELLOW}not configured${NC}"
    fi

    # Hostname
    echo -e "  Hostname:     ${BOLD}$(hostname)${NC}"
    echo -e "  Uptime:       $(uptime -p 2>/dev/null || uptime)"
    echo ""

    # Blockchain
    echo -e "  ${BOLD}Blockchain${NC}"
    if command -v geth &>/dev/null; then
        if systemctl is-active nexus-geth.service &>/dev/null; then
            block=$(geth attach --exec "eth.blockNumber" /opt/nexus/blockchain/geth.ipc 2>/dev/null || echo "N/A")
            peers=$(geth attach --exec "net.peerCount" /opt/nexus/blockchain/geth.ipc 2>/dev/null || echo "N/A")
            echo -e "    Geth:       ${GREEN}running${NC} | Block: ${block} | Peers: ${peers}"
        else
            echo -e "    Geth:       ${RED}stopped${NC}"
        fi
    else
        echo -e "    Geth:       ${YELLOW}not installed${NC}"
    fi

    # IPFS
    if command -v ipfs &>/dev/null; then
        if ipfs swarm peers &>/dev/null; then
            peer_count=$(ipfs swarm peers 2>/dev/null | wc -l)
            echo -e "    IPFS:       ${GREEN}running${NC} | Peers: ${peer_count}"
        else
            echo -e "    IPFS:       ${RED}stopped${NC}"
        fi
    else
        echo -e "    IPFS:       ${YELLOW}not installed${NC}"
    fi
    echo ""

    # Services
    echo -e "  ${BOLD}Services${NC}"
    for svc in nexus-node-agent nexus-gateway nexus-dashboard-api; do
        if systemctl is-active "${svc}.service" &>/dev/null; then
            echo -e "    ${svc}: ${GREEN}running${NC}"
        else
            echo -e "    ${svc}: ${RED}stopped${NC}"
        fi
    done
}

cmd_wallet() {
    echo -e "${CYAN}${BOLD}═══ NEXUS Wallet ═══${NC}"
    echo ""

    if [ -f "$CONFIG_DIR/device_identity.json" ]; then
        addr=$(python3 -c "import json; print(json.load(open('$CONFIG_DIR/device_identity.json')).get('address','unknown'))" 2>/dev/null)
        echo -e "  Address: ${BOLD}${addr}${NC}"
    elif [ -f "$CONFIG_DIR/node_config.json" ]; then
        addr=$(python3 -c "import json; print(json.load(open('$CONFIG_DIR/node_config.json')).get('wallet_address','unknown'))" 2>/dev/null)
        echo -e "  Address: ${BOLD}${addr}${NC}"
    else
        echo -e "  Address: ${YELLOW}not generated (run first-boot setup)${NC}"
        return
    fi

    echo ""

    # Query token balances via gateway API
    if curl -s --max-time 3 "${GATEWAY}/api/tokens/balance/${addr}" &>/dev/null; then
        balances=$(curl -s --max-time 5 "${GATEWAY}/api/tokens/balance/${addr}" 2>/dev/null)
        if [ -n "$balances" ]; then
            echo -e "  ${BOLD}Token Balances${NC}"
            echo "$balances" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for token, bal in data.items():
        print(f'    {token}: {bal}')
except:
    print('    Unable to parse balances')
" 2>/dev/null
        fi
    else
        echo -e "  ${YELLOW}Gateway not reachable — cannot fetch balances${NC}"
        echo -e "  Start services: ${BOLD}sudo systemctl start nexus-gateway${NC}"
    fi
}

cmd_dashboard() {
    echo -e "Opening NEXUS Command Center..."
    xdg-open "${GATEWAY}/dashboard/" 2>/dev/null || \
    chromium-browser "${GATEWAY}/dashboard/" &
}

cmd_health() {
    echo -e "${CYAN}${BOLD}═══ NEXUS Health Check ═══${NC}"
    echo ""

    checks_passed=0
    checks_total=0

    check() {
        local name="$1"
        local cmd="$2"
        checks_total=$((checks_total + 1))
        if eval "$cmd" &>/dev/null; then
            echo -e "  ${GREEN}✓${NC} ${name}"
            checks_passed=$((checks_passed + 1))
        else
            echo -e "  ${RED}✗${NC} ${name}"
        fi
    }

    check "Node Agent running"        "systemctl is-active nexus-node-agent.service"
    check "Gateway running"            "systemctl is-active nexus-gateway.service"
    check "Dashboard API running"      "systemctl is-active nexus-dashboard-api.service"
    check "Geth running"               "systemctl is-active nexus-geth.service"
    check "IPFS running"               "systemctl is-active ipfs.service"
    check "Gateway reachable"          "curl -s --max-time 3 ${GATEWAY}/api/health"
    check "Wallet configured"          "test -f $CONFIG_DIR/device_identity.json"
    check "Node config exists"         "test -f $CONFIG_DIR/node_config.json"
    check "Disk space > 1GB free"      "[ \$(df /opt/nexus --output=avail -B1G 2>/dev/null | tail -1 | tr -d ' ') -gt 1 ]"

    echo ""
    echo -e "  ${BOLD}${checks_passed}/${checks_total}${NC} checks passed"
}

cmd_logs() {
    echo -e "${CYAN}${BOLD}═══ NEXUS Logs (last 50 lines) ═══${NC}"
    echo ""

    # Show combined recent logs from all NEXUS services
    if [ -d "$LOG_DIR" ]; then
        for logfile in "$LOG_DIR"/*.log; do
            if [ -f "$logfile" ]; then
                name=$(basename "$logfile" .log)
                echo -e "${BOLD}--- ${name} ---${NC}"
                tail -n 15 "$logfile"
                echo ""
            fi
        done
    fi

    # Also show journald logs for NEXUS services
    echo -e "${BOLD}--- systemd journal ---${NC}"
    journalctl -u 'nexus-*' --no-pager -n 20 --no-hostname 2>/dev/null || \
        echo "  No journal entries found"
}

cmd_nodes() {
    echo -e "${CYAN}${BOLD}═══ Connected Nodes ═══${NC}"
    echo ""

    # Try gateway API first
    nodes=$(curl -s --max-time 5 "${GATEWAY}/api/nodes" 2>/dev/null)
    if [ -n "$nodes" ] && echo "$nodes" | python3 -c "import sys,json; json.load(sys.stdin)" &>/dev/null; then
        echo "$nodes" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if isinstance(data, list):
    for node in data:
        name = node.get('name', 'unknown')
        ip = node.get('ip', '?')
        role = node.get('role', '?')
        status = node.get('status', '?')
        print(f'  {name:20s} {ip:16s} {role:12s} {status}')
else:
    print('  Unexpected response format')
" 2>/dev/null
        return
    fi

    # Fallback: IPFS swarm peers
    if command -v ipfs &>/dev/null && ipfs swarm peers &>/dev/null; then
        echo -e "  ${BOLD}IPFS Peers:${NC}"
        ipfs swarm peers 2>/dev/null | while read -r peer; do
            echo "    $peer"
        done
        return
    fi

    echo -e "  ${YELLOW}Gateway not reachable and IPFS not running.${NC}"
    echo -e "  Start services first: ${BOLD}sudo systemctl start nexus-gateway${NC}"
}

cmd_tasks() {
    echo -e "${CYAN}${BOLD}═══ Task Queue ═══${NC}"
    echo ""

    tasks=$(curl -s --max-time 5 "${GATEWAY}/api/tasks" 2>/dev/null)
    if [ -n "$tasks" ] && echo "$tasks" | python3 -c "import sys,json; json.load(sys.stdin)" &>/dev/null; then
        echo "$tasks" | python3 -c "
import sys, json
data = json.load(sys.stdin)
if isinstance(data, list):
    if not data:
        print('  No tasks in queue.')
    for task in data:
        tid = task.get('id', '?')[:8]
        name = task.get('name', 'unnamed')
        status = task.get('status', '?')
        print(f'  [{tid}] {name:30s} {status}')
else:
    print('  Unexpected response format')
" 2>/dev/null
    else
        echo -e "  ${YELLOW}Gateway not reachable — cannot fetch tasks${NC}"
    fi
}

# Main dispatch
case "${1:-help}" in
    status)    cmd_status ;;
    wallet)    cmd_wallet ;;
    dashboard) cmd_dashboard ;;
    health)    cmd_health ;;
    logs)      cmd_logs ;;
    nodes)     cmd_nodes ;;
    tasks)     cmd_tasks ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
