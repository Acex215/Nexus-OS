# NEXUS OS Tool Registry
# Defines all available tools with ECT costs, risk levels, and approval requirements
# Format: YAML | Last Updated: 2024-01-15

tools:
  - name: hid_controller
    description: Human Interface Device controller for keyboard/mouse input simulation
    ect_cost: 5
    risk_level: low
    md_approval_required: false
    capabilities:
      - keystroke_injection
      - mouse_movement
      - clipboard_access
    constraints:
      max_keystrokes_per_call: 100
      requires_physical_presence: true

  - name: ollama_subagent
    description: Local LLM inference via Ollama for reasoning and code generation tasks
    ect_cost: 25
    risk_level: medium
    md_approval_required: false
    capabilities:
      - text_completion
      - code_generation
      - reasoning
      - context_understanding
    constraints:
      model: qwen2.5-coder:7b
      max_tokens: 4096
      temperature: 0.7

  - name: ssh_execution
    description: Secure Shell command execution on cluster nodes for system operations
    ect_cost: 15
    risk_level: high
    md_approval_required: true
    capabilities:
      - remote_command_execution
      - file_transfer
      - service_control
    constraints:
      max_concurrent_sessions: 3
      requires_key_auth: true
      audit_logging: enabled
      allowed_commands:
        - systemctl
        - docker
        - kubectl
        - git

  - name: http_fetch
    description: HTTP/HTTPS request handler for web API interactions and data retrieval
    ect_cost: 3
    risk_level: low
    md_approval_required: false
    capabilities:
      - GET requests
      - POST requests
      - authentication_headers
      - response_parsing
    constraints:
      max_request_size_kb: 1024
      timeout_seconds: 30
      allowed_domains:
        - api.nexus.local
        - ipfs.nexus.local
